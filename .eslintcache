op();\n    columns.push({\n      title: \"\",\n      dataIndex: \"checkbox\",\n      render: () => <Checkbox />,\n    });\n  }\n\n  return (\n    <Card bordered={false} className=\"box-shadow  full-height\">\n      <Title className=\"card-title\" level={4}>\n        {props.cardTitle}\n        {props.cardTitle === \"PENDING CLEARANCE\" ? (\n          <a href=\"#\">\n            <LinkOutlined />\n          </a>\n        ) : null}\n      </Title>\n      {props.cardType === \"percentage\" ? (\n        <div>\n          <Title level={1}>\n            25\n            <PercentageOutlined style={{ fontSize: \"24px\", fontWeight: 700 }} />\n          </Title>\n        </div>\n      ) : null}\n      <Table\n        columns={columns}\n        dataSource={props.data}\n        pagination={false}\n        showHeader={false}\n      />\n    </Card>\n  );\n};\n","/Users/hashani/Documents/example repos/union-assuarance/src/constant.ts",[],{"ruleId":"23","replacedBy":"24"},{"ruleId":"25","replacedBy":"26"},{"ruleId":"27","severity":1,"message":"28","line":36,"column":11,"nodeType":"29","endLine":36,"endColumn":23},"no-native-reassign",["30"],"no-negated-in-lhs",["31"],"jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","no-global-assign","no-unsafe-negation"]